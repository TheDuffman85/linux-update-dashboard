Defaults:testuser !requiretty

testuser ALL=(root) NOPASSWD: /usr/bin/pacman -Sy --noconfirm
testuser ALL=(root) NOPASSWD: /usr/bin/pacman -Syu --noconfirm
testuser ALL=(root) NOPASSWD: /usr/bin/pacman -Rns --noconfirm -
testuser ALL=(root) NOPASSWD: /usr/bin/pacman -S --noconfirm *
testuser ALL=(root) NOPASSWD: /usr/bin/reboot ""
