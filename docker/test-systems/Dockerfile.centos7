FROM centos:7

# Point to vault repos since CentOS 7 is EOL
RUN sed -i 's/mirrorlist/#mirrorlist/g' /etc/yum.repos.d/CentOS-*.repo && \
    sed -i 's|#baseurl=http://mirror.centos.org|baseurl=http://vault.centos.org|g' /etc/yum.repos.d/CentOS-*.repo

RUN yum install -y openssh-server sudo \
        curl wget vim-minimal git nano \
        htop tree zip unzip && \
    yum clean all

# Configure SSH
RUN sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config && \
    sed -i 's/PasswordAuthentication no/PasswordAuthentication yes/' /etc/ssh/sshd_config

# Create a restricted package-maintenance user.
COPY sudoers/yum-nopasswd /etc/sudoers.d/testuser
RUN useradd -m -s /bin/bash testuser && \
    echo 'testpass' | passwd --stdin testuser && \
    chmod 440 /etc/sudoers.d/testuser && \
    visudo -cf /etc/sudoers.d/testuser

RUN su - testuser -c "sudo -n -l /usr/bin/yum update -y >/dev/null && \
    sudo -n -l /usr/bin/env ACCEPT_EULA=Y yum update -y >/dev/null && \
    ! sudo -n -l /usr/bin/env ACCEPT_EULA=N yum update -y >/dev/null && \
    ! sudo -n true"

# Generate host keys
RUN ssh-keygen -A

EXPOSE 22
CMD ["/usr/sbin/sshd", "-D"]
