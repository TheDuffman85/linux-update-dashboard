{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@server/*": ["./server/*"],
      "@client/*": ["./client/*"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "server/**/*.ts",
    "client/**/*.ts",
    "client/**/*.tsx",
    "*.d.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "tsup.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
