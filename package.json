{
  "name": "linux-update-dashboard",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "APP_VERSION=dev-$(date -u +'%Y%m%d%H%M'); VITE_APP_VERSION=\"$APP_VERSION\" LUDASH_APP_VERSION=\"$APP_VERSION\" bun run dev:server & VITE_APP_VERSION=\"$APP_VERSION\" LUDASH_APP_VERSION=\"$APP_VERSION\" bun run dev:client",
    "dev:server": "bun run --watch server/index.ts",
    "dev:client": "bunx --bun vite",
    "build": "vite build && bun build server/index.ts --outdir dist/server --target bun",
    "start": "bun run dist/server/index.js",
    "test": "bun test",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.3.0",
    "@types/sortablejs": "^1.15.9",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.9",
    "jose": "^6.2.2",
    "mqtt": "^5.15.1",
    "mustache": "^4.2.0",
    "nodemailer": "^8.0.2",
    "openid-client": "^6.3.0",
    "sortablejs": "^1.15.7",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.95.2",
    "@types/bun": "^1.3.11",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.15.0",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.13.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.2"
  },
  "overrides": {
    "rollup": "4.59.0"
  }
}
