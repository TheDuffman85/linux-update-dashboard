{
  "name": "linux-update-dashboard",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.9.0"
  },
  "scripts": {
    "dev": "APP_VERSION=dev-$(date -u +'%Y%m%d%H%M'); VITE_APP_VERSION=\"$APP_VERSION\" LUDASH_APP_VERSION=\"$APP_VERSION\" tsx watch server/index.ts & VITE_APP_VERSION=\"$APP_VERSION\" LUDASH_APP_VERSION=\"$APP_VERSION\" vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "generate:eol": "node scripts/generate-distro-lifecycle-data.mjs",
    "prebuild": "node scripts/generate-distro-lifecycle-data.mjs",
    "build": "vite build && tsup",
    "start": "node dist/server/index.js",
    "screenshots": "screenshots/create-screenshots.sh",
    "test": "vitest run",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "2.0.0",
    "@simplewebauthn/server": "^13.3.0",
    "@types/sortablejs": "^1.15.9",
    "bcryptjs": "3.0.3",
    "better-sqlite3": "12.11.1",
    "croner": "^10.0.1",
    "cronstrue": "^3.14.0",
    "drizzle-orm": "^0.45.1",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.27",
    "i18next": "^26.3.1",
    "jose": "^6.2.3",
    "mqtt": "^5.15.1",
    "mustache": "^4.2.0",
    "nodemailer": "^8.0.10",
    "openid-client": "^6.8.4",
    "prettier": "^3.9.4",
    "prettier-plugin-sh": "^0.18.1",
    "react-i18next": "^17.0.8",
    "sortablejs": "^1.15.7",
    "ssh2": "^1.16.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.101.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.15.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "^7.16.0",
    "tailwindcss": "^4.3.2",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "^6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  }
}
