{
  "name": "linux-update-dashboard",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.15.0"
  },
  "scripts": {
    "dev": "APP_VERSION=dev-$(date -u +'%Y%m%d%H%M'); VITE_APP_VERSION=\"$APP_VERSION\" LUDASH_APP_VERSION=\"$APP_VERSION\" pnpm run dev:server & VITE_APP_VERSION=\"$APP_VERSION\" LUDASH_APP_VERSION=\"$APP_VERSION\" pnpm run dev:client",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsup",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "2.0.0",
    "@simplewebauthn/server": "^13.3.0",
    "@types/sortablejs": "^1.15.9",
    "bcryptjs": "3.0.3",
    "better-sqlite3": "12.9.0",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.9",
    "jose": "^6.2.2",
    "mqtt": "^5.15.1",
    "mustache": "^4.2.0",
    "nodemailer": "^8.0.2",
    "openid-client": "^6.3.0",
    "sortablejs": "^1.15.7",
    "ssh2": "^1.16.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.95.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.15.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.13.2",
    "tailwindcss": "^4.2.2",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "^6.0.2",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  }
}
