# Optional local overrides for ./screenshots/create-screenshots.sh.
# Copy this file to screenshots/.env if your machine needs different ports or paths.

# CHROME_PATH=/usr/bin/google-chrome
# LUDASH_SCREENSHOT_FRONTEND_PORT=5173
# LUDASH_SCREENSHOT_BACKEND_PORT=3001
# LUDASH_SCREENSHOT_CHROME_PORT=9223
# LUDASH_SCREENSHOT_OUTPUT_DIR=/absolute/path/to/output

# The default key below is demo-only and used for the disposable screenshot DB.
# If you override it, keep it as a base64-encoded 32-byte key.
# LUDASH_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

